{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/agents-service/Dockerfile",
    "watchPatterns": [
      "apps/agents-service/**",
      "tradingagents/**",
      "cli/**",
      "pyproject.toml"
    ]
  },
  "deploy": {
    "startCommand": "/usr/local/bin/start-agents-service.sh",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
