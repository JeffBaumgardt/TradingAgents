# Copy to apps/api/.env — Node/tsx do not auto-load this file (unlike Next.js .env.local).
# The dev/start scripts pass --env-file=.env so variables are available at runtime.

# Supabase (copy real values from the Supabase dashboard Connect dialog — never commit the secret key)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=

# API gateway
PORT=4000
AGENTS_SERVICE_URL=http://localhost:8000
CORS_ORIGIN=http://localhost:3000

# Clerk session verification (same application as apps/web/.env.local)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
# Optional: JWT public key from Clerk dashboard for faster token verification
#CLERK_JWT_KEY=
# Optional: extra authorized frontend origins (comma-separated) if you use a custom dev URL
#CLERK_AUTHORIZED_PARTIES=http://127.0.0.1:3000

# Clerk webhook (optional — required for /webhooks/clerk)
#CLERK_WEBHOOK_SIGNING_SECRET=

# Stripe Managed Payments Checkout (optional — without these, checkout stays scaffolded)
# Obtain keys from https://dashboard.stripe.com/apikeys
#STRIPE_SECRET_KEY=
#STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret for POST /webhooks/stripe (Stripe CLI or Dashboard)
#STRIPE_WEBHOOK_SECRET=
# Price IDs from the Stripe Dashboard product catalog (Managed Payments–eligible tax code txcd_10103100)
#STRIPE_PRICE_BYOK_MONTHLY=price_1TvTHbRVFeboXyilYtahx9XM
#STRIPE_PRICE_BYOK_ANNUAL=price_1TvTsqRVFeboXyilEyklrsMr
#STRIPE_PRICE_HOSTED_MONTHLY=price_1TvTOaRVFeboXyilBPMIkcNy
#STRIPE_PRICE_HOSTED_ANNUAL=price_1TvTsqRVFeboXyilxIiWVyov
# Origin for Checkout success/cancel redirects (defaults to CORS_ORIGIN)
#WEB_APP_ORIGIN=http://localhost:3000

# Encrypt user provider API keys at rest (required). Generate once and keep stable:
#   openssl rand -base64 32
CREDENTIALS_ENCRYPTION_KEY=

# Feedback email (Resend) — required for POST /feedback; omit key to get a clear 503
RESEND_API_KEY=
FEEDBACK_TO_EMAIL=jeff@bugfoot.net
FEEDBACK_FROM_EMAIL=TradingAgents Feedback <onboarding@resend.dev>
