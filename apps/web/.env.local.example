NEXT_PUBLIC_API_URL=http://localhost:4000

# Clerk authentication (https://dashboard.clerk.com)
# Sign-in/up URLs must match the paths configured in your Clerk dashboard.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Point Clerk webhooks at http://localhost:4000/webhooks/clerk (via ngrok in dev)
CLERK_WEBHOOK_SIGNING_SECRET=

# Also required by the API gateway (apps/api) for JWT verification
# CLERK_SECRET_KEY is shared with the web app above
